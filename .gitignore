# ---------------------------------------------------------------------------
# Novus .gitignore
# Keeps personal/per-user state and runtime-generated files out of the repo.
# This governs GIT only; what actually SHIPS is controlled by .packwizignore
# and build.sh's SHIP_DENYLIST.
# ---------------------------------------------------------------------------

# Worlds & player identity (personal — never versioned)
saves
usercache.json
usernamecache.json
/cherishedworlds-favorites.dat
servers.dat
servers.dat_old

# Runtime output (regenerated every launch)
logs
crash-reports
screenshots
local
.mixin.out

# Per-user client settings (each player owns their own copy)
emi.json
patchouli_data.json
rhino.local.properties
config/betterdays-common.toml
config/lighty.config

# Per-world generated data (not a shippable default)
config/chunky/tasks/*
data/surveyor/*

# Simple Voice Chat — per-user/client state (never ship)
config/voicechat/
config/voicechat-client.toml

# Sinytra Connector runtime-generated remaps (host-specific; regenerated per client)
mods/.connector/
mods/.connectorEarly/

# packwiz build outputs & vendored tooling (regenerated by build.sh / CI)
/dist
/tools/packwiz

# README credits generator — Python cache
tools/readme/__pycache__/

/docs/refs/*.jar
/docs/refs/extracted/
